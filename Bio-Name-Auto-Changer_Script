-- ===== GET COLOR FUNCTION =====
local colorIndex = 1
local colorUpdateTimer = 0
local colorUpdateInterval = 0.1

local function GetNextColor()
    if UseAllColors then
        local color = RainbowColors[colorIndex]
        colorIndex = colorIndex + 1
        if colorIndex > #RainbowColors then
            colorIndex = 1
        end
        return color
    else
        Hue = (Hue + (HueIncrement * ColorSpeed)) % 1
        return Color3.fromHSV(Hue, 1, 1)
    end
end

-- ===== RAINBOW FUNCTION =====
local function StartRainbow()
    local nameToUse = NameTextBox.Text ~= "" and NameTextBox.Text or GetDisplayName()
    
    if nameToUse == "" then
        print("❌ Name is empty!")
        if StatusLabel and StatusLabel.Parent then
            StatusLabel.Text = "❌ Name is empty!"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        return
    end
    
    Word = nameToUse
    charCount = 1
    
    if Connection then
        Connection:Disconnect()
    end
    
    _G.RainbowStop = false
    isRunning = true
    print("✓ Started: " .. Word)
    if StatusLabel and StatusLabel.Parent then
        StatusLabel.Text = "✅ Running: " .. Word
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    end
    
    Connection = RunService.Heartbeat:Connect(function(dt)
        if _G.RainbowStop or Word == "" then
            if Connection then
                Connection:Disconnect()
                Connection = nil
            end
            isRunning = false
            return
        end

        -- ===== GET COLOR =====
        local NewColor
        if UseAllColors then
            colorUpdateTimer = colorUpdateTimer + dt
            if colorUpdateTimer >= colorUpdateInterval / ColorSpeed then
                colorUpdateTimer = 0
                NewColor = GetNextColor()
                
                -- Update Color Box (اگر GUI موجود ہو)
                if NameColorBox and NameColorBox.Parent then
                    NameColorBox.BackgroundColor3 = NewColor
                end
                
                -- RP NAME COLOR
                pcall(function()
                    ColorRemote:FireServer(NewColor)
                end)

                -- BIO COLOR
                lastBioUpdate = lastBioUpdate + dt
                if lastBioUpdate >= BioUpdateFrequency then
                    lastBioUpdate = 0
                    pcall(function()
                        if isBioColorRemoteFunction then
                            BioColorRemote:InvokeServer(NewColor)
                        else
                            BioColorRemote:FireServer(NewColor)
                        end
                    end)
                end
            end
        else
            Hue = (Hue + (HueIncrement * ColorSpeed)) % 1
            NewColor = Color3.fromHSV(Hue, 1, 1)

            if NameColorBox and NameColorBox.Parent then
                NameColorBox.BackgroundColor3 = NewColor
            end

            pcall(function()
                ColorRemote:FireServer(NewColor)
            end)

            lastBioUpdate = lastBioUpdate + dt
            if lastBioUpdate >= BioUpdateFrequency then
                lastBioUpdate = 0
                pcall(function()
                    if isBioColorRemoteFunction then
                        BioColorRemote:InvokeServer(NewColor)
                    else
                        BioColorRemote:FireServer(NewColor)
                    end
                end)
            end
        end

        -- ===== TEXT TYPING (NameSpeed کے ساتھ) =====
        lastNameUpdate = lastNameUpdate + dt
        if lastNameUpdate >= NameSpeed then
            lastNameUpdate = 0
            local DisplayText = string.sub(Word, 1, charCount)
            
            pcall(function()
                NameRemote:FireServer(DisplayText)
            end)

            charCount = (charCount >= #Word) and 1 or (charCount + 1)
        end
    end)
end

-- ===== SPEED INPUT EVENT =====
SpeedInput.FocusLost:Connect(function()
    local speedValue = tonumber(SpeedInput.Text)
    if speedValue then
        speedValue = math.clamp(speedValue, 0.01, 1.0)
        NameSpeed = speedValue
        SpeedInput.Text = tostring(speedValue)
        SpeedLabel.Text = "⚡ Name Change Speed: " .. speedValue .. "s"
        print("⚡ Speed changed to: " .. speedValue .. " seconds")
    else
        SpeedInput.Text = tostring(NameSpeed)
    end
end)

